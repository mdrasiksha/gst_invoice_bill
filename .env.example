SECRET_KEY=change-me
# Leave DATABASE_URL unset for local SQLite. Set this to Render PostgreSQL in production.
# DATABASE_URL=postgresql://user:password@host:5432/database
SESSION_COOKIE_SECURE=true
MAX_CONTENT_LENGTH=2097152

# Optional one-time admin bootstrap. Existing users are never overwritten.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change-me-too
RESEND_API_KEY=
FROM_EMAIL=noreply@gstsmart.com
APP_URL=https://gstsmart.com
REPLY_TO_EMAIL=gstsmartsupport@gmail.com
